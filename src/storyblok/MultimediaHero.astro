---
import { storyblokEditable } from '@storyblok/astro'

const { blok } = Astro.props
---

<header {...storyblokEditable(blok)} class="multimedia-hero">
  <div class="container">
    <div class="hero-content stagger-container">
      {blok.label && <span class="archive-label reveal reveal-up" style="--stagger-index: 1;">{blok.label}</span>}
      <h1 class="hero-headline reveal reveal-up" style="--stagger-index: 2;">{blok.headline}</h1>
      <div class="accent-line reveal reveal-left" style="--stagger-index: 3;"></div>
    </div>
  </div>
</header>

<style>
  .multimedia-hero {
    padding-top: 15rem; /* Space for the sticky header */
    padding-bottom: 6rem;
    background-color: #000000;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .archive-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #94a3b8;
    font-weight: 500;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 9vw, 7.5rem);
    font-weight: 300;
    color: #ffffff;
    line-height: 1.1;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .accent-line {
    width: 100px;
    height: 1px;
    background-color: var(--color-primary);
    margin-top: 2rem;
    opacity: 0.5;
  }

  @media (max-width: 1024px) {
    .multimedia-hero {
      padding-top: 12rem;
      padding-bottom: 4rem;
    }
  }

  @media (max-width: 768px) {
    .hero-headline {
      font-size: 3rem;
    }
    .multimedia-hero {
       padding-top: 4rem;
       padding-bottom: 0;
    }
  }
</style>
