---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'
import StoryblokImage from '../components/StoryblokImage.astro'

const { blok } = Astro.props

const bgImage = blok.background_image?.filename
const opacity = blok.overlay_opacity || '0.5'
---

<section {...storyblokEditable(blok)} class="hero-section">
  {bgImage && (
    <div class="hero-bg">
      <StoryblokImage 
        src={bgImage} 
        alt={blok.background_image?.alt || "Berna Perles Background"}
        width={1920}
        height={1080}
        loading="eager"
        fetchpriority="high"
        class="hero-img"
        sizes="100vw"
      />
      <div class="hero-overlay" style={`background-color: rgba(0, 0, 0, ${opacity});`}></div>
    </div>
  )}

  <div class="hero-container">
    <div class="hero-content">
      {blok.soprao_label && <span class="hero-label">{blok.soprao_label}</span>}
      <h1 class="hero-title">
        <span class="title-part-1">{blok.title_part_1}</span>
        <span class="title-part-2">{blok.title_part_2}</span>
      </h1>
      
      {blok.quote_text && <p class="hero-quote">{blok.quote_text}</p>}

      <div class="hero-buttons">
        {
          blok.button_blocks?.map((nestedBlok: any) => {
            return <StoryblokComponent blok={nestedBlok} />
          })
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    min-height: 100vh; /* True full screen */
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--color-on-surface);
    background-color: #000; /* Fallback */
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  :global(.hero-img),
  :global(.hero-img img) {
    width: 100%;
    height: 100% !important;
    object-fit: cover;
    object-position: center;
    aspect-ratio: auto !important;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-container {
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem;
    height: 100vh; /* Match section height */
    display: flex;
    align-items: center; /* Center content vertically */
    justify-content: flex-end;
    position: relative;
    z-index: 2;
  }

  .hero-content {
    max-width: 650px;
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5); /* Improved readability over complex backgrounds */
  }

  .hero-label {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.75rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
    font-weight: 500;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 5.5rem);
    line-height: 0.95;
    margin-bottom: 1.5rem;
    display: flex;
    gap: 0.3ch;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .title-part-1 {
    font-weight: 700;
    color: #ffffff;
  }

  .title-part-2 {
    font-weight: 300;
    font-style: italic;
    color: var(--color-primary);
  }

  .hero-quote {
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 3.5vw, 1.35rem);
    line-height: 1.5;
    margin-bottom: 3rem;
    font-style: italic;
    font-weight: 300;
    opacity: 1;
    color: #ffffff;
    text-wrap: balance;
  }

  .hero-buttons {
    display: flex;
    gap: 1.5rem;
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero-section {
      min-height: 100vh;
    }
    .hero-container {
      justify-content: center;
      padding: 6rem 1.5rem 2rem;
      text-align: center;
    }
    .hero-content {
      text-align: center;
      align-items: center;
    }
    .hero-title, .hero-buttons {
      justify-content: center;
    }
    .hero-quote {
      margin-bottom: 2rem;
    }
  }
</style>
