---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'

const { blok } = Astro.props
---

<div {...storyblokEditable(blok)} class="contact-social-bar">
  <div class="bar-content">
    {blok.label && <span class="bar-label">{blok.label}</span>}
    <div class="icons-row">
      {blok.icons?.map((iconBlok: any) => (
        <StoryblokComponent blok={iconBlok} />
      ))}
    </div>
  </div>
</div>

<style>
  .contact-social-bar {
    background-color: #000000;
    border-radius: 2.5rem;
    padding: 2.5rem;
    margin-top: 1.5rem;
  }

  .bar-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .bar-label {
    font-family: var(--font-body);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #64748b;
    font-weight: 600;
  }

  .icons-row {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  /* Target the footer_social_icon components */
  .icons-row :global(svg) {
    width: 24px;
    height: 24px;
    color: #ffffff;
    transition: all 0.3s ease;
    opacity: 0.6;
  }

  .icons-row :global(a:hover svg) {
    color: var(--color-primary);
    opacity: 1;
    transform: translateY(-3px);
  }

  @media (max-width: 768px) {
    .icons-row {
      gap: 1.5rem;
    }
  }
</style>
