---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'

const { blok } = Astro.props
---

<section {...storyblokEditable(blok)} class="featured-roles-section">
  <div class="container">
    <h2 class="section-title reveal reveal-up">{blok.title}</h2>
    
    <div class="roles-grid stagger-container">
      {blok.roles_list && blok.roles_list.map((subblok: any, index: number) => (
        <div class="reveal reveal-up" style={`--stagger-index: ${index + 1};`}>
          <StoryblokComponent blok={subblok} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-roles-section {
    padding: 8rem 0;
    background-color: #0c0c0c; /* Matching the deep black theme */
    color: var(--color-on-surface);
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 300;
    text-align: center;
    margin-bottom: 5rem;
    color: #ffffff;
  }

  .roles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  @media (max-width: 1100px) {
    .roles-grid {
      gap: 2rem;
    }
  }

  @media (max-width: 1024px) {
    .roles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .featured-roles-section {
      padding: 4rem 0;
    }
  }

  @media (max-width: 768px) {
    .roles-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .section-title {
      margin-bottom: 3.5rem;
    }
  }
</style>
