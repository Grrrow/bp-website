---
import { storyblokEditable, renderRichText } from '@storyblok/astro'
import StoryblokImage from '../components/StoryblokImage.astro';

const { blok } = Astro.props

const renderedRichText = renderRichText(blok.content)
---

<section {...storyblokEditable(blok)} class="trajectory-section">
  <div class="container">
    <div class="trajectory-grid">
      <div class="trajectory-content reveal reveal-right stagger-container">
        <div class="title-wrapper reveal reveal-right" style="--stagger-index: 1;">
          <div class="accent-bar"></div>
          <h2 class="trajectory-title">{blok.title}</h2>
        </div>
        
        <div class="trajectory-text reveal reveal-right" style="--stagger-index: 2;" set:html={renderedRichText} />
      </div>

      <div class="trajectory-image-wrapper reveal reveal-left">
        {blok.image && blok.image.filename && (
          <div class="circular-image-container image-reveal active">
            <StoryblokImage 
              src={blok.image.filename} 
              alt={blok.image.alt || "Berna Perles Trayectoria"} 
              width={800}
              height={800}
              class="trajectory-img"
            />
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .trajectory-section {
    padding: 8rem 0;
    background-color: #0c0c0c; /* Deep black to match the design */
    color: var(--color-on-surface);
    overflow: hidden;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .trajectory-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .title-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
  }

  .accent-bar {
    width: 2px;
    height: 3rem;
    background-color: var(--color-primary); /* Mint green bar */
    flex-shrink: 0;
    margin-top: 0.5rem;
  }

  .trajectory-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    margin: 0;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .trajectory-text {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.9;
    color: #a0a0a0; /* Muted gray for premium feel */
    max-width: 85%;
  }

  .trajectory-text :global(p) {
    margin-bottom: 2.5rem;
  }

  .trajectory-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .trajectory-text :global(em) {
    color: #e0e0e0;
    font-style: italic;
  }

  .trajectory-image-wrapper {
    display: flex;
    justify-content: flex-end;
    position: relative;
  }

  .circular-image-container {
    width: 100%;
    max-width: 600px;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    overflow: hidden;
    position: relative;
    box-shadow: 0 40px 80px rgba(0,0,0,0.9);
    border: 1px solid rgba(255, 255, 255, 0.08); /* Subtle highlight */
  }

  :global(.trajectory-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(10%) contrast(1.05); /* Slight polish */
  }

  @media (max-width: 1100px) {
    .trajectory-grid {
      gap: 4rem;
    }
    .trajectory-text {
      max-width: 100%;
    }
  }

  @media (max-width: 1024px) {
    .trajectory-section {
      padding: 4rem 0;
    }
    .trajectory-grid {
      grid-template-columns: 1fr;
    }
    .trajectory-image-wrapper {
      margin-top: 5rem;
      max-width: 450px;
      margin-left: auto;
      margin-right: auto;
    }
    .accent-bar {
        height: 2.2rem;
    }
  }

  @media (max-width: 768px) {
    .trajectory-title {
      font-size: 2.25rem;
    }
    .trajectory-text {
      font-size: 1.1rem;
    }
  }
</style>
