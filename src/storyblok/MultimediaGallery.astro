---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'

const { blok } = Astro.props

const photoLabel = blok.photo_tab_label || "Fotos"
const videoLabel = blok.video_tab_label || "Videos"
---

<section {...storyblokEditable(blok)} class="multimedia-gallery-section" id="multimedia-gallery">
  <div class="container">
    <nav class="gallery-tabs">
      <button class="tab-btn active" data-tab="photos">
        {photoLabel}
        <span class="underline"></span>
      </button>
      <button class="tab-btn" data-tab="videos">
        {videoLabel}
        <span class="underline"></span>
      </button>
    </nav>

    <div class="tabs-content">
      <!-- Photos Grid -->
      <div class="gallery-grid active" id="photos-grid">
        {blok.photos_items && blok.photos_items.map((subblok: any) => (
          <StoryblokComponent blok={subblok} />
        ))}
      </div>

      <!-- Videos Grid -->
      <div class="gallery-grid" id="videos-grid">
        {blok.video_items && blok.video_items.map((subblok: any) => (
          <StoryblokComponent blok={subblok} />
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function initGalleryTabs() {
    const section = document.querySelector('#multimedia-gallery');
    if (!section) return;

    const buttons = section.querySelectorAll('.tab-btn');
    const grids = section.querySelectorAll('.gallery-grid');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetTab = btn.getAttribute('data-tab');

        // Update buttons
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Update grids
        grids.forEach(grid => {
          grid.classList.remove('active');
          if (grid.id === `${targetTab}-grid`) {
            grid.classList.add('active');
          }
        });
      });
    });
  }

  // Initialize on page load and after swaps if using View Transitions
  initGalleryTabs();
  document.addEventListener('astro:after-swap', initGalleryTabs);
</script>

<style>
  .multimedia-gallery-section {
    padding: 4rem 0 10rem 0;
    background-color: #000000;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .gallery-tabs {
    display: flex;
    justify-content: center;
    gap: 4rem;
    margin-bottom: 5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .tab-btn {
    background: none;
    border: none;
    color: #94a3b8;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    padding: 1.5rem 0;
    cursor: pointer;
    position: relative;
    transition: color 0.3s ease;
  }

  .tab-btn:hover {
    color: #ffffff;
  }

  .tab-btn.active {
    color: #ffffff;
  }

  .underline {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    transform: scaleX(0);
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .tab-btn.active .underline {
    transform: scaleX(1);
  }

  .tabs-content {
    position: relative;
    min-height: 400px;
  }

  .gallery-grid {
    display: none; /* Hidden by default */
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 350px;
    gap: 2rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .gallery-grid.active {
    display: grid;
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 1100px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 300px;
    }
  }

  @media (max-width: 768px) {
    .multimedia-gallery-section {
      padding: 0 0 6rem 0;
    }
    .gallery-tabs {
      gap: 2rem;
      margin-bottom: 3.5rem;
    }
    .tab-btn {
      font-size: 1.125rem;
    }
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 350px;
      gap: 1.5rem;
    }
  }
</style>
