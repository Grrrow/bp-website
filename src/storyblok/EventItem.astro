---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'

const { blok, isPast = false } = Astro.props

// Date Formatting
const dateObj = new Date(blok.date_start)
const day = dateObj.getDate().toString().padStart(2, '0')
const month = dateObj.toLocaleDateString('es-ES', { month: 'long' }).toUpperCase()
const year = dateObj.getFullYear()

// Handle Tickets Button
const hasTickets = !isPast && blok.tickets_button && blok.tickets_button.length > 0
---

<div {...storyblokEditable(blok)} class:list={["event-item", { "event-item-past": isPast }]}>
  <!-- Date Column -->
  <div class="calendar-date">
    {!isPast ? (
      <>
        <span class="day">{day}</span>
        <span class="month-year">{month} {year}</span>
      </>
    ) : (
      <span class="month-year archive-date">{month} {year}</span>
    )}
  </div>

  <!-- Content Column -->
  <div class="event-info">
    <h3 class="event-title">{blok.title}</h3>
    <div class="event-location">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="location-icon">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
        <circle cx="12" cy="10" r="3" />
      </svg>
      <span>{blok.location}</span>
    </div>
  </div>

  <!-- Action Column -->
  <div class="event-action">
    {isPast ? (
       <div class="finished-label">FINALIZADO</div>
    ) : (
      hasTickets && blok.tickets_button.map((btnBlok: any) => (
        <div class="btn-mint-wrapper">
           <StoryblokComponent blok={btnBlok} />
        </div>
      ))
    )}
  </div>
</div>

<style>
  .event-item {
    display: grid;
    grid-template-columns: 160px 1fr 180px; /* More balanced columns */
    align-items: center;
    padding: 3.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: background-color 0.3s ease;
    gap: 2rem;
  }

  .event-item:hover {
    background-color: rgba(255, 255, 255, 0.02);
  }

  .calendar-date {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .day {
    font-family: var(--font-body);
    font-size: 2.5rem;
    font-weight: 300;
    color: #ffffff;
    line-height: 1;
  }

  .month-year {
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #94a3b8;
    font-weight: 500;
  }

  .event-info {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .event-title {
    font-family: var(--font-body);
    font-size: 1.35rem;
    font-weight: 400;
    color: #ffffff;
    margin: 0;
  }

  .event-location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #94a3b8;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 300;
  }

  .location-icon {
    width: 1rem;
    height: 1rem;
    opacity: 0.6;
  }

  /* Custom Button Styling for Calendar */
  .btn-mint-wrapper :global(.btn) {
    background: linear-gradient(135deg, #79e5a1 0%, #a5f3bc 100%);
    color: #0c0c0c !important;
    border: none !important;
    border-radius: 100px !important;
    padding: 1rem 2.5rem !important;
    font-weight: 600 !important;
    font-size: 0.75rem !important;
    text-transform: uppercase !important;
    letter-spacing: 0.15em !important;
    box-shadow: 0 4px 15px rgba(121, 229, 161, 0.2);
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
    min-width: 160px;
  }

  .finished-label {
    display: inline-flex;
    padding: 0.5rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
    justify-content: center;
    width: fit-content;
  }

  .event-item-past {
    opacity: 0.7;
    padding: 2.5rem 0;
  }

  .event-item-past .event-title {
    font-size: 1.5rem;
    color: #d1d5db;
  }

  .archive-date {
    font-size: 0.825rem;
    color: #64748b;
  }

  @media (max-width: 1024px) {
    .event-item {
      grid-template-columns: 150px 1fr 180px;
    }
    .day {
      font-size: 2.75rem;
    }
  }

  @media (max-width: 768px) {
    .event-item {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 3rem 0;
      text-align: left;
    }
    .calendar-date {
      flex-direction: row;
      align-items: baseline;
      gap: 1rem;
    }
    .day {
      font-size: 3rem;
    }
    .event-action {
      display: flex;
      justify-content: flex-start;
    }
  }
</style>
