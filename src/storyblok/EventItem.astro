---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'

const { blok } = Astro.props

// Helper to format dates
const formatDate = (dateStr: string) => {
  if (!dateStr) return null
  const date = new Date(dateStr.replace(' ', 'T')) // Handle Storyblok date format
  return {
    day: date.getDate(),
    month: date.toLocaleString('es-ES', { month: 'short' }).toUpperCase().replace('.', ''),
    year: date.getFullYear()
  }
}

const start = formatDate(blok.date_start)
const end = formatDate(blok.date_end)

// Logic for range display
let displayMonth = start?.month
let displayYear = start?.year?.toString()
let displayDay = start?.day?.toString()

if (end && start) {
  if (start.month === end.month && start.year === end.year) {
    displayDay = `${start.day} — ${end.day}`
  } else if (start.year === end.year) {
    displayMonth = `${start.month} — ${end.month}`
    displayDay = `${start.day} — ${end.day}`
  } else {
    // Cross-year range
    displayMonth = `${start.month} ${start.year} — ${end.month} ${end.year}`
    displayYear = "" // Clear it as it's included in displayMonth now
    displayDay = `${start.day} — ${end.day}`
  }
}

const hasHighlightLine = blok.highlight_line || false // For future use/flexible styling
---

<div {...storyblokEditable(blok)} class="event-card">
  <div class="date-column">
    <div class="date-block">
      <div class="month-year">
        {start?.month === end?.month && start?.year === end?.year ? (
          <span>{start?.month} {start?.year}</span>
        ) : (
          <span>{start?.month}{start?.year === end?.year ? '' : ' ' + start?.year} — {end?.month} {end?.year}</span>
        )}
      </div>
      <div class="day">
        {start?.day}{end && (start?.day !== end?.day || start?.month !== end?.month) ? ` — ${end.day}` : ''}
      </div>
    </div>
  </div>

  <div class="content-column">
    <div class="title-wrapper">
      <h3 class="event-title">{blok.title}</h3>
    </div>
    <div class="location">
      <svg class="pin-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 12.75C13.6569 12.75 15 11.4069 15 9.75C15 8.09315 13.6569 6.75 12 6.75C10.3431 6.75 9 8.09315 9 9.75C9 11.4069 10.3431 12.75 12 12.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M19.5 9.75C19.5 16.5 12 21 12 21C12 21 4.5 16.5 4.5 9.75C4.5 7.761 5.29018 5.85322 6.6967 4.4467C8.10322 3.04018 10.011 2.25 12 2.25C13.989 2.25 15.8968 3.04018 17.3033 4.4467C18.7098 5.85322 19.5 7.761 19.5 9.75V9.75Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {blok.location}
    </div>
  </div>

  <div class="actions-column">
    {
      blok.tickets_button?.map((nestedBlok: any) => {
        return <StoryblokComponent blok={nestedBlok} />
      })
    }
  </div>
</div>

<style>
  .event-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 3rem;
    padding: 2.5rem 3rem;
    background-color: var(--color-surface-low);
    border-radius: 12px;
    margin-bottom: 1rem;
    align-items: center;
    transition: transform 0.3s ease, background-color 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .event-card:hover {
    background-color: var(--color-surface-high);
    transform: translateY(-4px);
  }

  /* Date Styling */
  .date-column {
    display: flex;
    flex-direction: column;
    text-align: left;
    border-right: 1px solid rgba(255, 255, 255, 0.15);
    padding-right: 2.5rem;
    min-width: 140px;
  }

  .date-block {
    display: flex;
    flex-direction: column;
  }

  .month-year {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    font-family: var(--font-body);
    font-weight: 600;
  }

  .day {
    font-size: 2.5rem;
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1;
    color: #ffffff;
    white-space: nowrap;
  }

  /* Content Styling */
  .content-column {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .event-title {
    font-size: 1.5rem;
    font-family: var(--font-display);
    font-weight: 400;
    color: #ffffff;
  }

  .location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    opacity: 0.6;
    font-weight: 300;
  }

  .pin-icon {
    width: 16px;
    height: 16px;
    color: var(--color-primary);
  }

  /* Actions Styling */
  .actions-column {
    display: flex;
    justify-content: flex-end;
  }

  @media (max-width: 768px) {
    .event-card {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding: 2rem;
      text-align: center;
    }
    .date-column {
      border-right: none;
      padding-right: 0;
      align-items: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      padding-bottom: 1.5rem;
    }
    .location {
      justify-content: center;
    }
    .actions-column {
      justify-content: center;
    }
  }
</style>
