---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokImage from '../components/StoryblokImage.astro'

const { blok } = Astro.props
---

<div {...storyblokEditable(blok)} class="contact-portrait-card">
  <div class="image-wrapper">
    <StoryblokImage 
      src={blok.image?.filename} 
      alt={blok.image?.alt || blok.name}
      width={1200}
      height={1600}
      class="portrait-img"
    />
    <div class="portrait-overlay">
      <div class="info">
        <h3 class="name">{blok.name}</h3>
        <span class="role">{blok.role}</span>
      </div>
    </div>
  </div>
</div>

<style>
  .contact-portrait-card {
    width: 100%;
    height: 100%;
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 3.5rem;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .contact-portrait-card:hover .portrait-img {
    transform: scale(1.03);
  }

  .portrait-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 3rem;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
    display: flex;
    align-items: flex-end;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .name {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: #ffffff;
    margin: 0;
    font-weight: 500;
  }

  .role {
    font-family: var(--font-body);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #d1d5db;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .image-wrapper {
        border-radius: 2.5rem;
    }
    .portrait-overlay {
        padding: 2rem;
    }
    .name {
        font-size: 1.5rem;
    }
  }
</style>
