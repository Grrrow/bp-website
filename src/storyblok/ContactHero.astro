---
import { storyblokEditable } from '@storyblok/astro'

const { blok } = Astro.props
---

<header {...storyblokEditable(blok)} class="contact-hero">
  <div class="container">
    <div class="hero-content">
      {blok.label && <span class="archive-label">{blok.label}</span>}
      <h1 class="hero-headline">{blok.headline}</h1>
    </div>
  </div>
</header>

<style>
  .contact-hero {
    padding-top: 15rem;
    padding-bottom: 5rem;
    background-color: #000000;
    text-align: center;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .archive-label {
    font-family: var(--font-body);
    font-size: 0.825rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #94a3b8;
    font-weight: 500;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 8.5rem);
    font-weight: 300;
    color: #ffffff;
    line-height: 0.95;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .accent-line {
    width: 60px;
    height: 1px;
    background-color: var(--color-primary);
    margin-top: 2rem;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .contact-hero {
      padding-top: 4rem;
    }
    .hero-headline {
      font-size: 3rem;
    }
  }
</style>
