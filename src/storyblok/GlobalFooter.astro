---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'

const { blok } = Astro.props
---

<footer {...storyblokEditable(blok)} class="footer">
  <div class="footer-content">
    <div class="footer-left">
      <div class="footer-logo">
        {blok.artist_logo?.filename ? (
          <img src={blok.artist_logo.filename} alt={blok.artist_logo.alt || "Berna Perles"} />
        ) : (
          <div class="logo-text"><strong>Berna</strong> <em>Perles</em></div>
        )}
      </div>
      <div class="social-links">
        {
          blok.social_icons_block?.map((nestedBlok: any) => {
            return <StoryblokComponent blok={nestedBlok} />
          })
        }
      </div>
    </div>

    <div class="footer-right">
      {blok.management_title && <h3 class="management-title">{blok.management_title}</h3>}
      <div class="contact-items">
        {
          blok.contact_details_block?.map((nestedBlok: any) => {
            return <StoryblokComponent blok={nestedBlok} />
          })
        }
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>{blok.copyright_text}</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-surface);
    color: var(--color-on-surface);
    padding: 4rem 2rem 2rem;
    margin-top: auto;
  }
  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 4rem;
  }
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .footer-logo img {
    height: 40px;
    width: auto;
  }
  .logo-text {
    font-size: 1.75rem;
    font-family: var(--font-display);
  }
  .logo-text strong {
    font-weight: 700;
  }
  .logo-text em {
    color: var(--color-primary);
    font-style: italic;
    font-weight: normal;
  }
  .social-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: right;
  }
  .management-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.25rem;
    margin: 0;
  }
  .contact-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .footer-bottom {
    max-width: 1200px;
    margin: 4rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
    font-size: 0.875rem;
    opacity: 0.6;
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 3rem;
    }
    .footer-left {
      align-items: center;
    }
    .footer-right {
      text-align: center;
      align-items: center;
    }
  }
</style>
