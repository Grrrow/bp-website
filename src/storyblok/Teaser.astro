---
import { storyblokEditable } from '@storyblok/astro'

const { blok } = Astro.props
---

<div {...storyblokEditable(blok)} class="teaser-block">
  <h2>{blok.headline}</h2>
</div>

<style>
  .teaser-block {
    text-align: center;
    padding: 3rem 1rem;
    background: #fdfdfd;
    border-bottom: 1px solid #eee;
  }
  h2 {
    font-size: 2.5rem;
    color: #222;
  }
</style>
