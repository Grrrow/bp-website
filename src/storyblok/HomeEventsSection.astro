---
import { storyblokEditable } from '@storyblok/astro'
import StoryblokComponent from '@storyblok/astro/StoryblokComponent.astro'

const { blok } = Astro.props
---

<section {...storyblokEditable(blok)} class="calendar-section">
  <div class="container">
    <div class="header-row">
      <div class="title-group">
        <div class="section-label-wrapper">
          <span class="section-label">{blok.label}</span>
        </div>
        <h2 class="section-headline">{blok.headline}</h2>
      </div>

      <div class="header-actions">
        {
          blok.view_all_button?.map((nestedBlok: any) => {
            return <StoryblokComponent blok={nestedBlok} />
          })
        }
      </div>
    </div>

    <div class="events-list">
      {
        blok.event?.map((nestedBlok: any) => {
          return <StoryblokComponent blok={nestedBlok} />
        })
      }
    </div>
  </div>
</section>

<style>
  .calendar-section {
    padding: var(--spacing-24) 0;
    background-color: var(--color-surface);
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
  }

  /* Label with line */
  .section-label-wrapper {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .section-label-wrapper::before {
    content: '';
    width: 3rem;
    height: 2px;
    background-color: var(--color-primary);
    opacity: 0.8;
  }

  .section-label {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.75rem;
    color: var(--color-primary);
    font-weight: 500;
  }

  .section-headline {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
  }

  .events-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .calendar-section {
      padding: 3.5rem 0;
    }
    .header-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
      margin-bottom: 3rem;
    }
    .header-actions {
      width: 100%;
    }
    :global(.header-actions a) {
      width: 100%;
      justify-content: center;
    }
  }
</style>
