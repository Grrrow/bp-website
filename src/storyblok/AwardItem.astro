---
import { storyblokEditable } from '@storyblok/astro'

const { blok } = Astro.props
---

<div {...storyblokEditable(blok)} class="award-item">
  <div class="award-year">
    <span>{blok.year}</span>
  </div>
  
  <div class="award-content">
    <h3 class="award-title">{blok.title}</h3>
    <p class="award-description">{blok.description}</p>
  </div>
</div>

<style>
  .award-item {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 3rem;
    align-items: flex-start;
  }

  .award-year {
    font-family: var(--font-body);
    font-size: 2.25rem;
    font-weight: 700;
    color: #334155; /* Darker silver/gray for the year */
    line-height: 1;
    text-align: right;
  }

  .award-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .award-title {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0;
  }

  .award-description {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: #94a3b8;
    margin: 0;
  }

  @media (max-width: 768px) {
    .award-item {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      text-align: center;
    }
    
    .award-year {
      text-align: center;
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }

    .award-content {
      align-items: center;
    }
  }
</style>
