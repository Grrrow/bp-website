---
/**
 * StoryblokImage.astro
 * Componente de alto rendimiento optimizado para Core Web Vitals.
 * Implementa <picture> con formatos AVIF/WebP y srcset adaptativo.
 */

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  quality?: number;
  smart?: boolean;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  sizes?: string;
  aspectRatio?: string;
}

const {
  src,
  alt,
  width,
  height,
  quality = 75,
  smart = true,
  loading = 'lazy',
  fetchpriority = 'auto',
  class: className,
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 1200px',
  aspectRatio: customAspectRatio,
} = Astro.props;

if (!src) return null;

const isStoryblok = src.includes('a.storyblok.com');

/**
 * Genera la URL optimizada para un ancho y formato específicos.
 */
const getUrl = (w: number | string, f: 'webp' | 'avif' | 'original' = 'webp') => {
  if (!isStoryblok) return src;
  
  const baseUrl = src.replace('https://a.storyblok.com', '');
  // Calculamos el alto proporcional si existe el original para mantener aspect ratio
  const h = height && width ? Math.round(Number(height) * (Number(w) / width)) : '';
  
  let transform = `/m/${w}x${h}/`;
  if (smart) transform += 'smart/';
  
  const filters = [];
  if (f !== 'original') filters.push(`format(${f})`);
  filters.push(`quality(${quality})`);
  filters.push('no_upscale()');
  
  return `https://a.storyblok.com${baseUrl}${transform}filters:${filters.join(':')}`;
};

/**
 * Genera el srcset para un formato dado.
 */
const getSrcset = (f: 'webp' | 'avif') => {
  if (!isStoryblok) return null;
  // Breakpoints estándar para optimización adaptativa - Incluyendo 300 para móvil
  const widths = [300, 400, 800, 1200, 1600];
  return widths
    .map(w => `${getUrl(w, f)} ${w}w`)
    .join(', ');
};

const avifSrcset = isStoryblok ? getSrcset('avif') : null;
const webpSrcset = isStoryblok ? getSrcset('webp') : null;
const fallbackUrl = width ? getUrl(width, 'webp') : src;

// Lógica de Aspect Ratio para reservar espacio (CLS)
const finalAspectRatio = customAspectRatio || (width && height ? `${width} / ${height}` : undefined);
---

<picture class:list={['sb-picture', className]}>
  {isStoryblok && (
    <>
      <source type="image/avif" srcset={avifSrcset} sizes={sizes} />
      <source type="image/webp" srcset={webpSrcset} sizes={sizes} />
    </>
  )}
  <img
    src={fallbackUrl}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
    style={finalAspectRatio ? `aspect-ratio: ${finalAspectRatio};` : ''}
  />
</picture>

<style>
  .sb-picture {
    display: block;
    line-height: 0;
  }
  
  img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
    object-fit: cover;
    background-color: rgba(31, 32, 32, 0.3);
    transition: opacity 0.5s ease-in;
  }

  /* Evitar transición en LCP para máxima velocidad percibida */
  img[loading="eager"] {
    transition: none;
  }
</style>
