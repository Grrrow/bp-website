---
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

// Target language is the opposite of current language
const targetLang = lang === 'es' ? 'en' : 'es';

function getAlternativeUrl(target: string) {
  if (target === 'es') {
    return currentPath.replace(/^\/en/, '') || '/';
  } else if (target === 'en') {
    return currentPath === '/' ? '/en' : `/en${currentPath}`;
  }
  return currentPath;
}

const targetUrl = getAlternativeUrl(targetLang);
---

<a href={targetUrl} class="language-picker" aria-label={`Switch to ${targetLang === 'es' ? 'Spanish' : 'English'}`}>
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"></circle>
    <line x1="2" y1="12" x2="22" y2="12"></line>
    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
  </svg>
</a>

<style>
.language-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-on-surface);
  text-decoration: none;
  transition: opacity 0.3s ease, transform 0.3s ease, color 0.3s ease;
  cursor: pointer;
  padding: 0.25rem;
}
.language-picker:hover {
  opacity: 0.8;
  transform: scale(1.05);
  color: var(--color-primary);
}
</style>
